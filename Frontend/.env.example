# Copiar a .env.local para desarrollo local:
#   cp .env.example .env.local
#
# El frontend siempre consume el backend via esta variable.
# No hardcodear URLs en el codigo.

# --- Desarrollo local ---
# Frontend: npm run dev  ->  http://localhost:3001
# Backend:  npm run dev  ->  http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000

# --- Produccion en Vercel ---
# No editar aqui: configurar en el dashboard de Vercel del proyecto Frontend
# (Settings > Environment Variables), para Production y Preview:
#
#   NEXT_PUBLIC_API_URL=https://tu-proyecto-backend.vercel.app
#
# Pasos para desplegar el Frontend en Vercel:
#   1. Nuevo proyecto en Vercel, conectar este repositorio.
#   2. Root Directory: Frontend
#   3. Framework: Next.js (auto-detectado)
#   4. Agregar NEXT_PUBLIC_API_URL con la URL publica del backend desplegado.
#   5. Deploy
#
# Mientras el companero no despliegue el backend, segui usando localhost arriba.
