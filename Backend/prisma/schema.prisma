generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
}

enum MovementType {
  ENTRADA
  SALIDA
}

model User {
  id           String              @id @default(cuid())
  name         String
  email        String              @unique
  image        String?
  passwordHash String
  role         Role                @default(USER)
  enabled      Boolean             @default(true)
  deleted      Boolean             @default(false)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  createdBooks Book[]              @relation("BookCreator")
  movements    InventoryMovement[] @relation("MovementResponsible")
}

model Book {
  id          String              @id @default(cuid())
  name        String
  author      String?
  isbn        String?             @unique
  description String?
  stock       Int                 @default(0)
  enabled     Boolean             @default(true)
  deleted     Boolean             @default(false)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  createdById String
  createdBy   User                @relation("BookCreator", fields: [createdById], references: [id])
  movements   InventoryMovement[]

  @@index([name])
  @@index([createdById])
}

model InventoryMovement {
  id             String       @id @default(cuid())
  type           MovementType
  quantity       Int
  previousStock  Int
  resultingStock Int
  note           String?
  createdAt      DateTime     @default(now())
  bookId         String
  book           Book         @relation(fields: [bookId], references: [id])
  responsibleId  String
  responsible    User         @relation("MovementResponsible", fields: [responsibleId], references: [id])

  @@index([bookId, createdAt])
  @@index([responsibleId])
}
